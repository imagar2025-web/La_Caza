APP_NAME="La Caza"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://tu-app.railway.app
APP_KEY=

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}
DB_DATABASE=${DB_DATABASE}
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie

FRONTEND_URL=https://tu-frontend.railway.app
SANCTUM_STATEFUL_DOMAINS=tu-app.railway.app,localhost:3000
